# ===== 数据库连接 =====
POSTGRES_USER="vocab"
POSTGRES_PASSWORD="<请设置强密码>"
POSTGRES_DB="vocabmaster"
DATABASE_URL="postgresql://vocab:<你的数据库密码>@localhost:5432/vocabmaster?schema=public"

# ===== NextAuth 配置 =====
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<请使用 openssl rand -base64 32 生成强随机字符串>"

# ===== OAuth 配置（可选） =====
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===== 百度翻译 API（用于例句中文翻译和词库数据生成） =====
BAIDU_TRANSLATE_APPID=""
BAIDU_TRANSLATE_SECRET=""

# ===== 邮箱 SMTP（用于密码重置、邮箱验证等） =====
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ===== 应用 URL =====
NEXT_PUBLIC_BASE_PATH=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
