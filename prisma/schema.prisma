// ========== VocabMaster 数据库模型定义 ==========

generator client {
  provider      = "prisma-client-js"
  // Docker Alpine 镜像需要 musl + openssl 引擎
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== 用户模型 ==========
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // 密码哈希（邮箱注册用户）
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth 关联
  accounts Account[]
  sessions Session[]

  // 业务关联
  wordProgress   UserWordProgress[]
  learningSessions LearningSession[]
  dailyCheckIns  DailyCheckIn[]
  achievements   UserAchievement[]

  @@map("users")
}

// ========== NextAuth Account 模型 ==========
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ========== NextAuth Session 模型 ==========
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ========== NextAuth 验证令牌 ==========
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ========== 词库模型 ==========
model WordBook {
  id          String @id @default(cuid())
  name        String @unique // 词库名称（如 CET-4、雅思）
  description String // 词库描述
  level       String // 难度等级: beginner, intermediate, advanced
  category    String // 分类: exam, general
  wordCount   Int    @default(0) // 词汇总数
  coverColor  String @default("#2563eb") // 封面颜色
  sortOrder   Int    @default(0) // 排序顺序

  words Word[]

  @@map("word_books")
}

// ========== 单词模型 ==========
model Word {
  id                 String @id @default(cuid())
  bookId             String
  word               String // 英文单词
  phonetic           String? // 音标
  definition         String // 中文释义
  partOfSpeech       String? // 词性 (n. v. adj. adv. etc.)
  example            String? // 英文例句
  exampleTranslation String? // 例句翻译
  difficulty         Int    @default(1) // 难度 1-5
  frequency          Int    @default(0) // 词频排名（数值越大越常用，基于 COCA 词频表）

  book         WordBook           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userProgress UserWordProgress[]

  @@index([bookId])
  @@index([word])
  @@map("words")
}

// ========== 用户单词学习进度（SM-2 算法核心数据） ==========
model UserWordProgress {
  id              String   @id @default(cuid())
  userId          String
  wordId          String
  repetitions     Int      @default(0)  // 连续正确次数
  easinessFactor  Float    @default(2.5) // 难度因子 (>=1.3)
  interval        Int      @default(0)  // 复习间隔（天）
  nextReviewDate  DateTime @default(now()) // 下次复习日期
  totalReviews    Int      @default(0)  // 总复习次数
  correctCount    Int      @default(0)  // 正确次数
  status          String   @default("new") // new, learning, review, mastered

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, status])
  @@index([userId, nextReviewDate])
  @@map("user_word_progress")
}

// ========== 学习会话记录 ==========
model LearningSession {
  id               String   @id @default(cuid())
  userId           String
  bookId           String?  // 关联词库
  mode             String   // learn, review, spell, quiz
  startTime        DateTime @default(now())
  endTime          DateTime?
  newWordsCount    Int      @default(0)  // 新学单词数
  reviewWordsCount Int      @default(0)  // 复习单词数
  correctCount     Int      @default(0)  // 正确次数
  totalCount       Int      @default(0)  // 总题数

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@map("learning_sessions")
}

// ========== 每日打卡记录 ==========
model DailyCheckIn {
  id            String   @id @default(cuid())
  userId        String
  checkInDate   DateTime @db.Date // 打卡日期
  wordsLearned  Int      @default(0)  // 当日学习新词数
  wordsReviewed Int      @default(0)  // 当日复习词数
  studyMinutes  Int      @default(0)  // 学习时长（分钟）
  streak        Int      @default(1)  // 连续打卡天数

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkInDate])
  @@index([userId, checkInDate])
  @@map("daily_check_ins")
}

// ========== 成就定义 ==========
model Achievement {
  id               String @id @default(cuid())
  code             String @unique // 成就代码（如 vocab_learner, streak_master）
  name             String // 成就名称
  description      String // 成就描述
  category         String // 分类: learning, streak, review, accuracy, spelling, book, time, habit
  icon             String // 图标名称（lucide-react 图标名）
  bronzeThreshold  Int    // 铜牌阈值
  silverThreshold  Int    // 银牌阈值
  goldThreshold    Int    // 金牌阈值

  userAchievements UserAchievement[]

  @@map("achievements")
}

// ========== 用户成就进度 ==========
model UserAchievement {
  id            String    @id @default(cuid())
  userId        String
  achievementId String
  tier          String    @default("none") // none, bronze, silver, gold
  progress      Int       @default(0) // 当前进度值
  unlockedAt    DateTime? // 最近一次升级时间
  notified      Boolean   @default(false) // 是否已通知用户

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ========== 例句缓存 ==========
model WordExample {
  id          String   @id @default(cuid())
  wordText    String   // 查询的单词
  sentence    String   // 英文例句
  translation String?  // 中文翻译（如有）
  source      String   @default("free-dictionary") // 数据来源
  fetchedAt   DateTime @default(now())

  @@index([wordText])
  @@map("word_examples")
}

// ========== 词源缓存 ==========
model WordEtymology {
  id           String   @id @default(cuid())
  wordText     String   @unique // 查询的单词
  roots        Json?    // 词根词缀列表
  origin       String?  // 词源描述
  relatedWords Json?    // 同根词列表
  fetchedAt    DateTime @default(now())

  @@map("word_etymologies")
}
